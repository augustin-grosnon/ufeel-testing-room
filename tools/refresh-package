#!/usr/bin/env python3

import json
import os

lock_file_path = os.path.join(os.path.dirname(__file__), 'Packages', 'packages-lock.json')

def remove_entry_from_lock_file():
    if not os.path.exists(lock_file_path):
        print(f"Error: {lock_file_path} does not exist.")
        return

    with open(lock_file_path, 'r') as f:
        data = json.load(f)

    dependencies = data.get("dependencies", {})

    if "com.ufcorp.ufeel" in dependencies:
        print("Removing com.ufcorp.ufeel from dependencies...")
        del dependencies["com.ufcorp.ufeel"]
    else:
        print("com.ufcorp.ufeel not found in dependencies.")

    with open(lock_file_path, 'w') as f:
        json.dump(data, f, indent=2)

    print("Update completed.")

if __name__ == "__main__":
    remove_entry_from_lock_file()
